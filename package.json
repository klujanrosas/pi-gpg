{
	"name": "pi-gpg",
	"version": "0.1.0",
	"description": "Pi extension for agent-safe GPG commit signing. Routes passphrase prompts through Pi's UI so GnuPG never hijacks the TTY.",
	"type": "module",
	"license": "MIT",
	"author": "Kenneth Lujan",
	"homepage": "https://github.com/kennethlujan/pi-gpg",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kennethlujan/pi-gpg.git"
	},
	"bugs": {
		"url": "https://github.com/kennethlujan/pi-gpg/issues"
	},
	"keywords": [
		"pi-package",
		"pi-extension",
		"gpg",
		"git",
		"signing",
		"agent",
		"pinentry"
	],
	"engines": {
		"node": ">=20"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"files": [
		"src",
		"shim",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"provenance": true
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"format": "biome format --write .",
		"fix": "biome check --write .",
		"clean": "rm -rf node_modules .tsbuildinfo coverage",
		"build": "echo 'nothing to build — Pi loads TS via jiti' && npm run typecheck",
		"check": "npm run typecheck && npm run lint && npm test",
		"prepublishOnly": "npm run check",
		"release:patch": "npm version patch && git push --follow-tags",
		"release:minor": "npm version minor && git push --follow-tags",
		"release:major": "npm version major && git push --follow-tags"
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.5",
		"@mariozechner/pi-ai": "^0.70.0",
		"@mariozechner/pi-coding-agent": "^0.70.0",
		"@mariozechner/pi-tui": "^0.70.0",
		"@types/node": "^20.14.0",
		"typebox": "^1.1.32",
		"typescript": "^5.6.0",
		"vitest": "^2.1.0"
	}
}
